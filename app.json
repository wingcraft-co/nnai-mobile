{
  "expo": {
    "name": "NNAI Nomad",
    "slug": "nnai-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nnainomad",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "co.wingcraft.nnai.mobile",
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Select photos to attach to your post.",
        "NSPhotoLibraryAddUsageDescription": "Allow saving edited photos for your post.",
        "NSCameraUsageDescription": "Allow camera access to take a photo for your post.",
        "NSLocationWhenInUseUsageDescription": "Allow location access to auto-fill your current city.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "nnainomad",
              "com.googleusercontent.apps.962318799283-7tsqbo64f14h6hfvgrn8b4fbgp43o6s5"
            ]
          }
        ]
      }
    },
    "android": {
      "package": "co.wingcraft.nnai.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0c7c59",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Select photos to attach to your post.",
          "cameraPermission": "Allow camera access to take a photo for your post."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow location access to auto-fill your current city."
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "replace-with-eas-project-id"
      }
    },
    "owner": "wingcraft-co"
  }
}
